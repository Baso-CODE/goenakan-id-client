// ===============================================
// PRODUCTION TRACKING (NEW)
// Mencatat waktu produksi barang di pabrik/vendor
// ===============================================

model ProductionTracker {
  id             String           @id @default(uuid())
  orderId        String
  orderProductId String
  vendorId       String
  step           Int              @default(1)
  quantity       Int
  startDate      DateTime?
  endDate        DateTime?
  status         ProductionStatus @default(PENDING)
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  order          Order            @relation(fields: [orderId], references: [id])
  orderProduct   OrderProduct     @relation(fields: [orderProductId], references: [id], onDelete: Cascade)
  vendor         Vendor           @relation(fields: [vendorId], references: [id])

  @@map("production_trackers")
}

// ===============================================
// LOGISTICS / SHIPMENT SYSTEM (NEW)
// Mencatat pergerakan barang (Inbound & Outbound)
// ===============================================

model Shipment {
  id                 String            @id @default(uuid())
  orderId            String
  vendorId           String?
  deliveryNoteNumber String?
  trackingNumber     String?
  courierLink        String?
  step               Int               @default(1)
  type               ShipmentType
  method             ShippingMethod
  status             ShipmentStatus    @default(PREPARED)
  history            ShipmentHistory[]
  origin             String?
  destination        String?
  departureDate      DateTime?
  arrivalDate        DateTime?
  warranties         OrderWarranty[]
  notes              ShipmentNote[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  order              Order             @relation(fields: [orderId], references: [id])
  vendor             Vendor?           @relation(fields: [vendorId], references: [id])
  items              ShipmentItem[]

  @@map("shipments")
}

model ShipmentHistory {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     String
  note       String?
  city       String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
}

model ShipmentItem {
  id             String       @id @default(uuid())
  shipmentId     String
  orderProductId String
  totalCarton    Int?         @default(0)
  quantity       Int
  shipment       Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderProduct   OrderProduct @relation(fields: [orderProductId], references: [id], onDelete: Cascade)

  @@map("shipment_items")
}

model ShipmentNoteCategory {
  id        String         @id @default(uuid())
  name      String
  templates Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  notes     ShipmentNote[]

  @@map("shipment_note_categories")
}

// Tabel Transaksi Catatan per Shipment
model ShipmentNote {
  id         String @id @default(uuid())
  shipmentId String
  categoryId String
  content    String @db.Text

  createdAt DateTime @default(now())

  // Relations
  shipment Shipment             @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  category ShipmentNoteCategory @relation(fields: [categoryId], references: [id])

  @@map("shipment_notes")
}

model DeliveryNote {
  id             String         @id @default(uuid())
  orderId        String
  deliveryNumber String         @unique
  deliveryDate   DateTime
  type           DeliveryType
  status         DeliveryStatus
  remarks        String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  order          Order          @relation(fields: [orderId], references: [id])

  @@map("delivery_notes")
}

model Quotation {
  id              String          @id @default(uuid())
  quotationNumber String?         @unique
  date            DateTime        @default(now())
  validUntil      DateTime?
  status          QuotationStatus @default(DRAFT)

  // === CLIENT RELATION ===
  clientId String?
  client   Client?       @relation(fields: [clientId], references: [id])
  picId    String?
  pic      ClientB2BPIC? @relation(fields: [picId], references: [id])

  // === FINANCIALS, CURRENCY & TERMS ===
  currencyCode String   @default("IDR")
  currency     Currency @relation(fields: [currencyCode], references: [code])
  paymentTerms String?  @db.Text

  subTotal       Decimal         @default(0)
  taxAmount      Decimal?        @default(0)
  discountAmount Decimal?        @default(0)
  totalAmount    Decimal         @default(0)
  notes          QuotationNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // === RELATIONS ===
  orderId         String?
  order           Order?  @relation("OrderQuotations", fields: [orderId], references: [id])
  resultingOrders Order[] @relation("OrderSourcedFromQuotation")

  // === CREATED BY (INTERNAL SALES / USER) ===
  userId String?
  user   User?   @relation("QuotationCreatedBy", fields: [userId], references: [id])

  updatedById String?
  updatedBy   User?   @relation("QuotationUpdatedBy", fields: [updatedById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  items            QuotationItem[]
  followUps        QuotationFollowUp[]
  whatsappMessages WhatsappMessage[]

  @@map("quotations")
}

model QuotationNoteCategory {
  id        String @id @default(uuid())
  name      String
  templates Json?

  isPublic Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes QuotationNote[]

  @@map("quotation_note_categories")
}

model QuotationNote {
  id          String @id @default(cuid())
  quotationId String
  categoryId  String
  content     String @db.Text

  createdAt DateTime @default(now())

  quotation Quotation             @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  category  QuotationNoteCategory @relation(fields: [categoryId], references: [id])

  @@map("quotation_notes")
}

model QuotationFollowUp {
  id          String   @id @default(cuid())
  quotationId String
  date        DateTime @default(now())
  // === FIELD BARU ===
  name        String?
  method      String?
  notes       String?  @db.Text
  nextAction  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_follow_ups")
}

