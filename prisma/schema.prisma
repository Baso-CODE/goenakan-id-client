// ===============================================
// PURCHASE ORDER SECTION
// ===============================================
model PurchaseOrder {
  id              String              @id @default(uuid())
  poNumber        String              @unique
  poDate          DateTime            @default(now())
  purchaseType    PurchaseType
  expenseCategory ExpenseCategory
  paymentTerms    PaymentTerm
  vendorId        String
  vendor          Vendor              @relation(fields: [vendorId], references: [id])
  vendorAddress   String              @db.Text
  currencyCode    String              @default("IDR")
  currency        Currency            @relation(fields: [currencyCode], references: [code])
  totalAmount     Decimal             @default(0)
  status          PurchaseOrderStatus @default(DRAFT)
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  items           PurchaseOrderItem[]
  createdById     String?
  createdBy       User?               @relation("POCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?               @relation("POUpdatedBy", fields: [updatedById], references: [id])
  approvedById    String?
  approvedBy      User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  approvalDate    DateTime?

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemName         String
  productId        String?
  product          Product?      @relation(fields: [productId], references: [id])
  // === REFERENSI SO / SN ===
  // Relasi ke tabel Order (Opsional: karena tipe INDIRECT_EXPENSES / STOCK tidak pakai SO)
  orderId          String?
  order            Order?        @relation(fields: [orderId], references: [id])
  // === KALKULASI KUANTITAS ===
  quantityOrder    Int
  quantityStock    Int           @default(0)
  quantityPurchase Int
  uom              String
  // === KALKULASI HARGA ===
  unitPrice        Decimal
  totalAmount      Decimal
  remarks          String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("purchase_order_items")
}

// ===============================================
// CASHFLOW SECTION
// ===============================================

model Cashflow {
  id          String       @id @default(uuid())
  orderId     String
  description String
  amount      Decimal
  type        CashflowType
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  order       Order        @relation(fields: [orderId], references: [id])

  @@map("cashflows")
}

