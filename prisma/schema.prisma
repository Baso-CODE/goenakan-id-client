model QuotationItem {
  id            String              @id @default(cuid())
  quotationId   String
  productId     String?
  product       Product?            @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant?     @relation(fields: [variantId], references: [id])
  productName   String
  description   String?             @db.Text
  customization Json?
  discount      Decimal?            @default(0)
  remarks       String?
  imageUrl      String?
  imagePublicId String?
  quotation     Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  tiers         QuotationItemTier[]

  @@map("quotation_items")
}

model QuotationItemTier {
  id              String        @id @default(cuid())
  quotationItemId String
  minQuantity     Int
  maxQuantity     Int?
  quantityLabel   String?
  unitPrice       Decimal
  totalPrice      Decimal
  item            QuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@map("quotation_item_tiers")
}

model CashflowSummary {
  id             String   @id @default(uuid())
  orderId        String
  orderNumber    String?
  totalRevenue   Decimal
  totalCost      Decimal
  profitLoss     Decimal
  baseCurrencyId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order        Order             @relation(fields: [orderId], references: [id])
  baseCurrency Currency          @relation(fields: [baseCurrencyId], references: [code])
  revenues     CashflowRevenue[]
  costs        CashflowCost[]

  @@map("cashflow_summaries")
}

model CashflowRevenue {
  id           String   @id @default(uuid())
  cashflowId   String
  description  String
  productId    String?
  unitPrice    Decimal
  quantity     Int
  total        Decimal
  currency     String   @default("IDR")
  exchangeRate Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  summary      CashflowSummary @relation(fields: [cashflowId], references: [id])
  product      Product?        @relation(fields: [productId], references: [id])
  Currency     Currency?       @relation(fields: [currencyCode], references: [code])
  currencyCode String?

  @@map("cashflow_revenue")
}

model CashflowCost {
  id           String   @id @default(uuid())
  cashflowId   String
  description  String
  vendorId     String?
  costPerUnit  Decimal
  quantity     Int
  total        Decimal
  currency     String   @default("IDR")
  exchangeRate Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  summary      CashflowSummary @relation(fields: [cashflowId], references: [id])
  vendor       Vendor?         @relation(fields: [vendorId], references: [id])
  Currency     Currency?       @relation(fields: [currencyCode], references: [code])
  currencyCode String?

  @@map("cashflow_cost")
}

// ===============================================
// CURRENCY MASTER
// ===============================================

model Currency {
  code              String              @id
  symbol            String
  name              String
  cashflowSummaries CashflowSummary[]
  cashflowRevenues  CashflowRevenue[]
  cashflowCosts     CashflowCost[]
  orders            Order[]
  purchaseOrders    PurchaseOrder[]
  quotations        Quotation[]
  vendorPrices      VendorPriceRecord[]

  @@map("currencies")
}

