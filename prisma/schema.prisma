model QuotationItem {
  id            String              @id @default(cuid())
  quotationId   String
  productId     String?
  product       Product?            @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant?     @relation(fields: [variantId], references: [id])
  productName   String
  description   String?             @db.Text
  customization Json?
  discount      Decimal?            @default(0)
  remarks       String?
  imageUrl      String?
  imagePublicId String?
  quotation     Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  tiers         QuotationItemTier[]

  @@map("quotation_items")
}

model QuotationItemTier {
  id              String        @id @default(cuid())
  quotationItemId String
  minQuantity     Int
  maxQuantity     Int?
  quantityLabel   String?
  unitPrice       Decimal
  totalPrice      Decimal
  item            QuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@map("quotation_item_tiers")
}

model CashflowSummary {
  id             String   @id @default(uuid())
  orderId        String
  poNumber       String
  totalRevenue   Decimal
  totalCost      Decimal
  profitLoss     Decimal
  baseCurrencyId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order        Order             @relation(fields: [orderId], references: [id])
  baseCurrency Currency          @relation(fields: [baseCurrencyId], references: [code])
  revenues     CashflowRevenue[]
  costs        CashflowCost[]

  @@map("cashflow_summaries")
}

model CashflowRevenue {
  id           String   @id @default(uuid())
  cashflowId   String
  description  String
  productId    String?
  unitPrice    Decimal
  quantity     Int
  total        Decimal
  currency     String
  exchangeRate Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  summary      CashflowSummary @relation(fields: [cashflowId], references: [id])
  product      Product?        @relation(fields: [productId], references: [id])
  Currency     Currency?       @relation(fields: [currencyCode], references: [code])
  currencyCode String?

  @@map("cashflow_revenue")
}

model CashflowCost {
  id           String   @id @default(uuid())
  cashflowId   String
  description  String
  vendorId     String?
  costPerUnit  Decimal
  quantity     Int
  total        Decimal
  currency     String
  exchangeRate Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  summary      CashflowSummary @relation(fields: [cashflowId], references: [id])
  vendor       Vendor?         @relation(fields: [vendorId], references: [id])
  Currency     Currency?       @relation(fields: [currencyCode], references: [code])
  currencyCode String?

  @@map("cashflow_cost")
}

// ===============================================
// CURRENCY MASTER
// ===============================================

model Currency {
  code   String @id // ex: IDR, USD
  symbol String // ex: Rp, $
  name   String // ex: Rupiah, US Dollar

  cashflowSummaries CashflowSummary[]
  cashflowRevenues  CashflowRevenue[]
  cashflowCosts     CashflowCost[]

  @@map("currencies")
}

// ===============================================
// WEBSITE CONTENT: FAQ SECTION
// ===============================================

model FaqCategory {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  faqs Faq[]

  @@map("faq_categories")
}

model Faq {
  id           String   @id @default(uuid())
  question     String
  answer       String   @db.Text
  displayOrder Int      @default(0)
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relasi ke Kategori
  categoryId String
  category   FaqCategory @relation(fields: [categoryId], references: [id])

  @@map("faqs")
}

model HeroSlide {
  id    String @id @default(uuid())
  title String

  imageUrl      String
  imagePublicId String

  altText      String?  @db.Text
  ctaText      String?
  ctaLink      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("hero_slides")
}

model PopupBanner {
  id                   String @id @default(uuid())
  title                String
  desktopImageUrl      String
  desktopImagePublicId String

  mobileImageUrl      String
  mobileImagePublicId String

  altText String?
  linkUrl String?

  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("popup_banners")
}

model ClientLogo {
  id   String @id @default(uuid())
  name String

  // === IMAGE ===
  imageUrl      String
  imagePublicId String

  // === CONFIG ===
  altText    String?
  websiteUrl String?

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_logos")
}

model AppSetting {
  id          String  @id @default(uuid())
  googleAdsId String?
  gtmId       String?
  pixelId     String?

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model FinanceCategory {
  id          String          @id @default(uuid())
  name        String          @unique // Contoh: "Gaji Karyawan", "Listrik", "Sewa Gedung"
  slug        String          @unique
  type        TransactionType
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transactions FinanceTransaction[]

  @@map("finance_categories")
}

model FinanceTransaction {
  id              String          @id @default(uuid())
  transactionDate DateTime        @default(now())
  type            TransactionType
  amount          Decimal         @default(0)
  referenceNumber String?
  description     String          @db.Text

  method PaymentMethod?

  createdBy String
  user      User   @relation(fields: [createdBy], references: [id])

  categoryId String
  category   FinanceCategory @relation(fields: [categoryId], references: [id])

  salesId String?
  sales   Sales?  @relation(fields: [salesId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("finance_transactions")
}

// ===============================================
// WEBSITE CLIENT SECTION (B2C & E-Commerce B2B)
// ===============================================

model CustomerProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  accountType AccountType @default(INDIVIDUAL)

  // --- Kolom untuk INDIVIDUAL (B2C) ---
  // fullName diambil dari tabel User (User.name)
  phone String?

  // --- Kolom untuk CORPORATE (B2B) ---
  picName     String?
  picPhone    String? // Di form namanya picNumbers
  companyName String?
  department  String? // Contoh: "Marketing", "Procurement"

  // Alamat & Data Tambahan
  avatarUrl String?
  addresses CustomerAddress[]
  carts     Cart[]
  orders    WebOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_profiles")
}

model Cart {
  id        String          @id @default(uuid())
  profileId String          @unique // 1 User = 1 Active Cart
  profile   CustomerProfile @relation(fields: [profileId], references: [id])

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id     String @id @default(uuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  // Untuk menyimpan konfigurasi desain custom (jika ada fitur custom)
  customization Json?
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, variantId]) // Hindari duplikat produk yang sama di keranjang
  @@map("cart_items")
}

model CustomerAddress {
  id        String          @id @default(uuid())
  profileId String
  profile   CustomerProfile @relation(fields: [profileId], references: [id])

  label     String // ex: "Rumah", "Kantor"
  recipient String // Nama penerima
  phone     String

  // Detail Alamat
  country     String?
  province    String?
  city        String?
  district    String?
  postalCode  String?
  fullAddress String  @db.Text

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_addresses")
}

model WebOrder {
  id          String @id @default(uuid())
  orderNumber String @unique

  // ✨ 1. Jadikan profileId opsional (Beri tanda '?' )
  profileId String?
  profile   CustomerProfile? @relation(fields: [profileId], references: [id])

  // ✨ 2. Tambahkan kolom khusus untuk Guest Checkout
  guestName  String?
  guestEmail String?
  guestPhone String?

  shippingAddress Json
  subtotal        Decimal
  shippingCost    Decimal
  taxAmount       Decimal? @default(0)
  totalAmount     Decimal

  status        WebOrderStatus @default(PENDING_PAYMENT)
  paymentMethod String?
  paymentUrl    String?

  trackingNumber String?
  courier        String?

  items WebOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("web_orders")
}

model WebOrderItem {
  id         String   @id @default(uuid())
  webOrderId String
  webOrder   WebOrder @relation(fields: [webOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName String // Snapshot nama produk saat dibeli
  quantity    Int
  price       Decimal // Harga per satuan saat dibeli
  total       Decimal // quantity * price

  customization Json?
  notes         String?

  @@map("web_order_items")
}

// ===============================================
// ARTICLE SECTION
// ===============================================

model ArticleCategory {
  id          String   @id @default(uuid())
  name        String   @unique // contoh: "Tutorial", "Tips & Trik"
  slug        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@map("article_categories")
}

model Article {
  id    String @id @default(uuid())
  title String @db.VarChar(255)
  slug  String @unique

  content String @db.LongText

  // Meta data
  coverImage    String
  coverImageId  String?
  source        String? @db.Text
  coverImageAlt String?

  published   Boolean   @default(false)
  publishedAt DateTime?

  // Relasi Penulis (Author)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // Relasi Kategori
  categoryId String
  category   ArticleCategory @relation(fields: [categoryId], references: [id])

  relatedProducts ArticleProduct[]
  articleBanners  ArticleBanner[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("articles")
}

model ArticleProduct {
  articleId String
  productId String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([articleId, productId])
  @@map("article_products")
}

model ArticleBanner {
  id              String  @id @default(uuid())
  backgroundColor String  @db.VarChar(50)
  buttonText      String  @db.VarChar(100)
  ctaLink         String  @db.Text
  isActive        Boolean @default(false)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("article_banners")
}

model BrandClient {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  country      String
  logo         String
  logoId       String
  websiteUrl   String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brand_clients")
}

model Portfolio {
  id           String  @id @default(cuid())
  title        String
  slug         String  @unique
  clientName   String
  description  String? @db.Text
  image        String
  imageId      String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // Standard Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolios")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String   @db.VarChar(50)
  interest  String?  @db.VarChar(100)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}
