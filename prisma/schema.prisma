  nameId        String
  nameEn        String
  slug          String  @unique
  descriptionId String?
  descriptionEn String?

  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guarantees BestPriceGuarantee[]

  @@map("best_price_guarantee_categories")
}

model BestPriceGuarantee {
  id           Int                        @id @default(autoincrement())
  titleId      String
  titleEn      String
  contentId    String                     @db.Text
  contentEn    String                     @db.Text
  displayOrder Int                        @default(0)
  isActive     Boolean                    @default(true)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  categoryId   Int
  category     BestPriceGuaranteeCategory @relation(fields: [categoryId], references: [id])

  @@map("best_price_guarantees")
}

model HeroSlide {
  id    String @id @default(uuid())
  title String

  imageUrl      String
  imagePublicId String

  altText      String?  @db.Text
  ctaText      String?
  ctaLink      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("hero_slides")
}

model PopupBanner {
  id                   String @id @default(uuid())
  title                String
  desktopImageUrl      String
  desktopImagePublicId String

  mobileImageUrl      String
  mobileImagePublicId String

  altText String?
  linkUrl String?

  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("popup_banners")
}

model ClientLogo {
  id   String @id @default(uuid())
  name String

  // === IMAGE ===
  imageUrl      String
  imagePublicId String

  // === CONFIG ===
  altText    String?
  websiteUrl String?

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_logos")
}

model AppSetting {
  id          String  @id @default(uuid())
  googleAdsId String?
  gtmId       String?
  pixelId     String?

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model FinanceCategory {
  id           String               @id @default(uuid())
  name         String               @unique
  slug         String               @unique
  type         TransactionType
  description  String?
  isActive     Boolean              @default(true)
  isMarketing  Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  transactions FinanceTransaction[]

  @@map("finance_categories")
}

model FinanceTransaction {
  id              String          @id @default(uuid())
  transactionDate DateTime        @default(now())
  type            TransactionType
  amount          Decimal         @default(0)
  referenceNumber String?
  description     String          @db.Text
  method          PaymentMethod?
  createdBy       String
  user            User            @relation(fields: [createdBy], references: [id])
  categoryId      String
  category        FinanceCategory @relation(fields: [categoryId], references: [id])

  salesId String?
  sales   Sales?  @relation(fields: [salesId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("finance_transactions")
}

// ===============================================
// WEBSITE CLIENT SECTION (B2C & E-Commerce B2B)
// ===============================================

model CustomerProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  accountType AccountType @default(INDIVIDUAL)

  // --- Kolom untuk INDIVIDUAL (B2C) ---
  // fullName diambil dari tabel User (User.name)
  phone String?

  // --- Kolom untuk CORPORATE (B2B) ---
  picName     String?
  picPhone    String? // Di form namanya picNumbers
  companyName String?
  department  String? // Contoh: "Marketing", "Procurement"

  // Alamat & Data Tambahan
  avatarUrl String?
  addresses CustomerAddress[]
  carts     Cart[]
  orders    WebOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_profiles")
}

model Cart {
  id        String          @id @default(uuid())
  profileId String          @unique
  profile   CustomerProfile @relation(fields: [profileId], references: [id])

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id     String @id @default(uuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  customization Json?
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

model CustomerAddress {
  id          String          @id @default(uuid())
  profileId   String
  profile     CustomerProfile @relation(fields: [profileId], references: [id])
  label       String
  recipient   String
  phone       String
  country     String?
  province    String?
  city        String?
  district    String?
  postalCode  String?
  fullAddress String          @db.Text
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("customer_addresses")
}

model WebOrder {
  id              String           @id @default(uuid())
  orderNumber     String           @unique
  profileId       String?
  profile         CustomerProfile? @relation(fields: [profileId], references: [id])
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  shippingAddress Json
  subtotal        Decimal
  shippingCost    Decimal?
  customerNote    String?          @db.Text
  taxAmount       Decimal?         @default(0)
  totalAmount     Decimal
  status          WebOrderStatus   @default(PENDING_PAYMENT)
  canceledReason  String?          @db.Text
  paymentMethod   String?
  paymentUrl      String?
  items           WebOrderItem[]
  order           Order?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("web_orders")
}

model WebOrderItem {
  id          String          @id @default(uuid())
  webOrderId  String
  webOrder    WebOrder        @relation(fields: [webOrderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  productName String
  quantity    Int
  price       Decimal
  total       Decimal

  customization Json?
  notes         String?

  @@map("web_order_items")
}

// ===============================================
// ARTICLE SECTION
// ===============================================

model ArticleCategory {
  id          String   @id @default(uuid())
  name        String   @unique // contoh: "Tutorial", "Tips & Trik"
  slug        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@map("article_categories")
}

model Article {
  id   String @id @default(uuid())
  slug String @unique

  // === KONTEN BAHASA INDONESIA (DEFAULT) ===
  title_id         String  @db.VarChar(255)
  content_id       String  @db.LongText
  focusKeywords_id String? @db.Text

  // === KONTEN BAHASA INGGRIS (HASIL AUTO-TRANSLATE) ===
  title_en           String?   @db.VarChar(255)
  content_en         String?   @db.LongText
  focusKeywords_en   String?   @db.Text
  isTranslated       Boolean   @default(false)
  coverImage         String
  coverImageId       String?
  coverImageAlt      String?
  coverImageMobile   String?
  coverImageMobileId String?
  source             String?   @db.Text
  published          Boolean   @default(false)
  publishedAt        DateTime?
  authorName         String?   @db.VarChar(100)
  authorId           String
  author             User      @relation(fields: [authorId], references: [id])

  categoryId      String
  category        ArticleCategory  @relation(fields: [categoryId], references: [id])
  articleTags     ArticleTagMap[]
  relatedProducts ArticleProduct[]
  articleBanners  ArticleBanner[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  seo             ArticleSEO?

  @@map("articles")
}

model ArticleProduct {
  articleId String
  productId String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([articleId, productId])
  @@map("article_products")
}

model ArticleBanner {
  id              String  @id @default(uuid())
  backgroundColor String  @db.VarChar(50)
  buttonText      String  @db.VarChar(100)
  ctaLink         String  @db.Text
  isActive        Boolean @default(false)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("article_banners")
}

model ArticleTag {
  id        String          @id @default(uuid())
  name      String          @unique
  slug      String          @unique
  createdAt DateTime        @default(now())
  articles  ArticleTagMap[]

  @@map("article_tags")
}

model ArticleTagMap {
  articleId  String
  tagId      String
  article    Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleTag ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tag_pivot")
}

model ArticleSEO {
  id              String  @id @default(cuid())
  metaTitle       String? @db.VarChar(255)
  metaDescription String? @db.Text
  keywords        String? @db.Text
  canonicalUrl    String? @db.VarChar(255)
  ogTitle         String? @db.VarChar(255)
  ogDescription   String? @db.Text
  ogImage         String? @db.VarChar(255)
  robots          String? @default("index, follow") @db.VarChar(50)
  structuredData  String? @db.LongText
  articleId       String  @unique
  article         Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("article_seo")
}

model BrandClient {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  country      String
  logo         String
  logoId       String
  websiteUrl   String?
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  clientB2bId  String?
  clientB2b    ClientB2B? @relation(fields: [clientB2bId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brand_clients")
}

// ===============================================
// PORTFOLIO & EVENT CATEGORY SECTION
// ===============================================

model EventCategory {
  id           String      @id @default(cuid())
  title        String
  slug         String      @unique
  orderCount   Int         @default(0)
  image        String
  imageId      String
  displayOrder Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  portfolios   Portfolio[]

  @@map("event_categories")
}

model Portfolio {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  clientName      String
  description     String?        @db.Text
  image           String
  imageId         String
  orderQuantity   Int?           @default(0)
  projectDate     DateTime?
  displayOrder    Int            @default(0)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  eventCategoryId String?
  eventCategory   EventCategory? @relation(fields: [eventCategoryId], references: [id], onDelete: SetNull)

  @@map("portfolios")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String   @db.VarChar(50)
  interest  String?  @db.VarChar(100)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

model HeroBannerProduct {
  id            String   @id @default(uuid())
  title         String?  @db.Text
  subtitle      String?  @db.Text
  imageUrl      String
  imagePublicId String?
  linkUrl       String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("hero_banners")
}

model WhatsappMessage {
  id          String    @id @default(cuid())
  phoneNumber String
  message     String    @db.LongText
  type        String // "order_created", "quotation_sent", "payment_reminder"
  orderId     String?
  quotationId String?
  status      String    @default("pending") // "pending", "sent", "failed"
  sentAt      DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order     Order?     @relation(fields: [orderId], references: [id])
  quotation Quotation? @relation(fields: [quotationId], references: [id])

  @@index([phoneNumber])
  @@index([status])
  @@index([type])
  @@map("whatsapp_messages")
}
