// ===============================================
// PRISMA SCHEMA — GOENAKAN ID
// ===============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

// ===============================================
// ENUMS & MASTER TABLES
enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum WarrantyStatus {
  NOT_STARTED
  ACTIVE
  EXPIRED
  VOID
}

enum QuotationStatus {
  DRAFT
  SENT
  FOLLOW_UP
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum WebOrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

// enum Role {
//   SUPER_ADMIN
//   ADMIN_ARTICLE
//   ADMIN_INVOICE
//   CUSTOMER
// }

enum AccountType {
  INDIVIDUAL
  CORPORATE
}

enum ClientType {
  B2B
  B2C
}

enum VendorType {
  SERVICE
  PRODUCT
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceCategory {
  DP
  FULL_PAYMENT
  INSTALLMENT
  REMAINING_BALANCE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  QRIS
}

enum SalesCategory {
  SALES
  SAMPLE
}

enum CashflowType {
  IN
  OUT
}

enum InOutType {
  INBOUND
  OUTBOUND
}

enum DeliveryType {
  FULL
  PARTIAL
}

enum DeliveryStatus {
  SENT
  PENDING
  CANCELLED
}

enum ProductionStatus {
  PENDING
  IN_PRODUCTION
  COMPLETED
}

enum ShipmentType {
  INBOUND
  OUTBOUND
}

enum ShipmentStatus {
  PENDING
  PREPARED
  DISPATCHED
  ARRIVED
  CANCELLED
}

enum ShippingMethod {
  LAND
  SEA
  AIR
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PurchaseType {
  DIRECT_MATERIAL // Pembelian produk berdasarkan SO
  DIRECT_EXPENSES // Pembelian selain produk (ex: logistik) berdasarkan SO
  INDIRECT_EXPENSES // Pembelian diluar SO (listrik, air, dll)
  STOCK // Pembelian produk bukan berdasarkan SO
}

enum ExpenseCategory {
  PRODUCT
  PACKAGING
  LOGISTIC
  UTILITY
}

enum PaymentTerm {
  IMMEDIATELY
  NET_14 // 14 Days
  NET_30 // 30 Days
  NET_60 // 60 Days
}

enum ClientStatus {
  POTENTIAL
  OFFICIAL
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  SENT
  COMPLETED
  CANCELLED
}

// ===============================================
// USER TABLE
// ===============================================

model User {
  id                  String               @id @default(uuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  password            String?
  image               String?
  phone               String?
  roleId              String
  createdAt           DateTime             @default(now())
  articles            Article[]
  invoices            Invoice[]
  sessions            Session[]
  financeTransactions FinanceTransaction[]
  customerProfile     CustomerProfile?
  accounts            Account[]
  client              Client?
  createdOrders       Order[]              @relation("OrderCreatedBy")
  updatedOrders       Order[]              @relation("OrderUpdatedBy")
  createdPOs          PurchaseOrder[]      @relation("POCreatedBy")
  updatedPOs          PurchaseOrder[]      @relation("POUpdatedBy")
  approvedPOs         PurchaseOrder[]      @relation("POApprovedBy")
  orders              Order[]
  role                Role                 @relation(fields: [roleId], references: [id])
  createdQuotations   Quotation[]          @relation("QuotationCreatedBy")
  updatedQuotations   Quotation[]          @relation("QuotationUpdatedBy")
  approvedQuotations  Quotation[]          @relation("QuotationApprovedBy")

  @@map("users")
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  users User[]

  @@map("roles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===============================================
// CLIENT SECTION
// ===============================================
model PurchaseChannel {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi ke B2B dan B2C
  orders Order[]

  @@map("purchase_channels")
}

model Client {
  id         String       @id @default(uuid())
  custCode   String       @unique
  type       ClientType
  userId     String?      @unique
  user       User?        @relation(fields: [userId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  status     ClientStatus @default(OFFICIAL)
  b2b        ClientB2B?
  b2c        ClientB2C?
  orders     Order[]
  invoices   Invoice[]
  quotations Quotation[]

  @@map("clients")
}

model ClientB2C {
  id          String  @id
  prefix      String
  name        String
  phone       String?
  country     String?
  province    String?
  city        String?
  district    String?
  subDistrict String?
  postalCode  String?
  fullAddress String
  client      Client  @relation(fields: [id], references: [id])

  @@map("clients_b2c")
}

model ClientB2B {
  id           String         @id
  companyName  String
  departmentId String
  department   Department     @relation(fields: [departmentId], references: [id])
  phone        String?
  email        String?
  website      String
  country      String?
  province     String?
  city         String?
  district     String?
  subDistrict  String?
  postalCode   String?
  fullAddress  String
  pics         ClientB2BPIC[]
  client       Client         @relation(fields: [id], references: [id])
  brandClients BrandClient[]

  @@map("clients_b2b")
}

model ClientB2BPIC {
  id          String  @id @default(uuid())
  clientB2BId String
  prefix      String?
  name        String
  email       String?
  phone       String?

  clientB2B  ClientB2B   @relation(fields: [clientB2BId], references: [id])
  orders     Order[]
  quotations Quotation[]

  @@map("client_b2b_pics")
}

model Department {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientsB2B ClientB2B[]

  @@map("departments")
}

// ===============================================
// PRODUCT SECTION
// ===============================================

model ProductCategory {
  id             String         @id @default(uuid())
  slug           String         @unique
  name_id        String         @unique @map("name")
  description_id String?        @map("description") @db.Text
  name_en        String?
  description_en String?        @db.Text
  image          String?
  imageId        String?
  code           String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  products       Product[]
  itemCategories ItemCategory[]

  @@map("product_categories")
}

model ItemCategory {
  id                String          @id @default(uuid())
  name              String
  slug              String          @unique
  code              String          @unique
  description       String?         @db.Text
  productCategoryId String
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id])
  itemNames         ItemName[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  products          Product[]

  @@map("item_categories")
}

model ItemName {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique
  code           String
  description    String?      @db.Text
  itemCategoryId String
  itemCategory   ItemCategory @relation(fields: [itemCategoryId], references: [id])
  products       Product[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("item_names")
}

model Product {
  id              String                  @id @default(uuid())
  name            String
  sku             String                  @unique
  slug            String                  @unique
  description     String?                 @db.Text
  uom             String                  @default("pcs")
  basePrice       Decimal
  isCustom        Boolean                 @default(false)
  isMadeByOrder   Boolean                 @default(false)
  materialTypeId  String?
  materialType    MaterialType?           @relation(fields: [materialTypeId], references: [id])
  stock           Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  weight          Float?
  width           Float?
  height          Float?
  length          Float?
  categoryId      String
  category        ProductCategory         @relation(fields: [categoryId], references: [id])
  itemCategoryId  String?
  itemCategory    ItemCategory?           @relation(fields: [itemCategoryId], references: [id])
  itemNameId      String?
  itemName        ItemName?               @relation(fields: [itemNameId], references: [id])
  attributeValues ProductAttributeValue[]
  priceTiers      PriceTier[]
  tags            Tag[]
  invoiceItems    InvoiceItem[]
  orderProducts   OrderProduct[]
  quotationItems  QuotationItem[]
  cashflowRevenue CashflowRevenue[]
  images          ProductImage[]
  videos          ProductVideo[]
  productVariants ProductVariant[]
  attributes      Attribute[]
  seo             ProductSEO?
  articleProducts ArticleProduct[]
  cartItems       CartItem[]
  webOrderItems   WebOrderItem[]
  purchaseItems   PurchaseOrderItem[]

  mockupAreaX      Float?
  mockupAreaY      Float?
  mockupAreaWidth  Float?
  mockupAreaHeight Float?

  isMultiFace        Boolean             @default(false)
  mockupFrontImageId String?
  mockupBackImageId  String?
  vendorPrices       VendorPriceRecord[]

  @@map("products")
}

model MaterialType {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  code        String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("material_types")
}

model ProductSEO {
  id              String  @id @default(uuid())
  metaTitle       String?
  metaDescription String?
  keywords        String?
  canonicalUrl    String?

  ogTitle       String?
  ogDescription String?
  ogImage       String?

  structuredData String? @db.Text
  productId      String  @unique
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_seo")
}

model Attribute {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  position  Int      @default(0)
  type      String   @default("TEXT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  parentValueId String?
  parentValue   AttributeValue? @relation("ValueToSubAttributes", fields: [parentValueId], references: [id], onDelete: Cascade)

  values   AttributeValue[]        @relation("AttributeToValues")
  products ProductAttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String    @id @default(uuid())
  value       String
  position    Int       @default(0)
  attributeId String
  attribute   Attribute @relation("AttributeToValues", fields: [attributeId], references: [id], onDelete: Cascade)

  subAttributes                 Attribute[]                    @relation("ValueToSubAttributes")
  products                      ProductAttributeValue[]
  productVariantAttributeValues ProductVariantAttributeValue[]
  productImages                 ProductImage[]
  productImagesAsPosition       ProductImage[]                 @relation("PrintPositionValue")
  productImagesAsPrintSide      ProductImage[]                 @relation("PrintSideValue")

  @@map("attribute_values")
}

model ProductAttributeValue {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  attributeValueId String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])
  attribute        Attribute?     @relation(fields: [attributeId], references: [id])
  attributeId      String?
  priceModifier    Float?         @default(0)

  // New fields
  weight Float?
  width  Float?
  height Float?
  length Float?

  @@unique([productId, attributeValueId])
  @@map("product_attribute_values")
}

model ProductVariant {
  id          String   @id @default(uuid())
  sku         String   @unique
  stock       Int      @default(0)
  variantName String?
  price       Decimal?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weight Float?
  width  Float?
  height Float?
  length Float?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  attributeValues ProductVariantAttributeValue[]
  images          ProductVariantImage[]
  orderProducts   OrderProduct[]
  invoiceItems    InvoiceItem[]
  quotationItems  QuotationItem[]
  cartItems       CartItem[]
  webOrderItems   WebOrderItem[]
  priceTiers      PriceTier[]

  @@map("product_variants")
}

model ProductVariantAttributeValue {
  id String @id @default(uuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  attributeValueId String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([variantId, attributeValueId])
  @@map("product_variant_attribute_values")
}

model PriceTier {
  id          String   @id @default(uuid())
  minQuantity Int      @default(1)
  maxQuantity Int?
  price       Decimal
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt

  @@map("price_tiers")
}

model ProductVariantImage {
  id         String   @id @default(uuid())
  url        String
  publicId   String
  isFeatured Boolean? @default(false)
  altText    String?

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("product_variant_images")
}

model ProductImage {
  id             String  @id @default(uuid())
  url            String
  publicId       String
  isFeatured     Boolean @default(false)
  altText        String?
  mockupSideName String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  attributeValueId String?
  attributeValue   AttributeValue? @relation(fields: [attributeValueId], references: [id])

  printPositionValueId String?
  printPositionValue   AttributeValue? @relation("PrintPositionValue", fields: [printPositionValueId], references: [id])

  printSideValueId String?
  printSideValue   AttributeValue? @relation("PrintSideValue", fields: [printSideValueId], references: [id])

  mockupAreas ProductImageMockupArea[]

  @@map("product_images")
}

model ProductImageMockupArea {
  id          String  @id @default(uuid())
  x           Float
  y           Float
  width       Float
  height      Float
  label       String
  description String?

  // Real physical print size of this placement area
  physicalWidth  Float?
  physicalHeight Float?
  unit           String? @default("cm") // "cm" | "mm"

  productImageId String
  productImage   ProductImage @relation(fields: [productImageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_image_mockup_areas")
}

model ProductVideo {
  id         String  @id @default(uuid())
  url        String
  publicId   String
  title      String?
  isFeatured Boolean @default(false)
  altText    String?

  // Relasi ke Produk
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("product_videos")
}

// ===============================================
// INVOICE SECTION
// ===============================================

model Invoice {
  id            Int             @id @default(autoincrement())
  invoiceNumber String?         @unique
  clientId      String
  userId        String
  orderId       String?
  totalAmount   Decimal
  status        InvoiceStatus   @default(UNPAID)
  category      InvoiceCategory @default(FULL_PAYMENT)
  method        PaymentMethod?
  dueDate       DateTime?
  paymentDate   DateTime?
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id])
  client Client        @relation(fields: [clientId], references: [id])
  order  Order?        @relation(fields: [orderId], references: [id])
  items  InvoiceItem[]
  notes  InvoiceNote[]

  @@map("invoices")
}

model InvoiceItem {
  id            Int     @id @default(autoincrement())
  invoiceId     Int
  productId     String
  variantId     String?
  remarks       String?
  customization Json?

  quantity Int
  price    Decimal

  invoice Invoice         @relation(fields: [invoiceId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("invoice_items")
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   Product[]
  categories TagCategory[] @relation("TagCategoryToTag")

  @@map("tags")
}

model TagCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags Tag[] @relation("TagCategoryToTag")

  @@map("tag_categories")
}

model VendorPriceRecord {
  id              String  @id @default(uuid())
  productId       String?
  tempProductName String?
  status          String  @default("POTENTIAL")
  calculationMode String  @default("FIXED")
  tiers           Json?
  vendorId        String?
  serviceVendorId String?

  // Potential Supplier Sourcing Details
  supplierPlatform    String?
  supplierContactName String?
  supplierContactLink String?

  // Supplier Pricing details
  foreignPrice Decimal @db.Decimal(10, 2)
  currencyCode String  @default("RMB")
  exchangeRate Decimal @db.Decimal(10, 2)

  // Packaging details (Overridable from Product default)
  qtyPerCtn Int?     @default(1)
  length    Decimal? @db.Decimal(10, 2)
  width     Decimal? @db.Decimal(10, 2)
  height    Decimal? @db.Decimal(10, 2)
  weight    Decimal? @db.Decimal(10, 2)

  // Local delivery in Origin & Target
  gzDeliveryCost Decimal @default(0) @db.Decimal(10, 2)
  localFreight   Decimal @default(0) @db.Decimal(10, 2)
  seaFreightRate Decimal @default(10000000) @db.Decimal(12, 2)
  airFreightRate Decimal @default(260000) @db.Decimal(12, 2)
  moqCtn         Int     @default(1)

  // Target selling guides
  margin         Decimal @default(0) @db.Decimal(10, 2)
  sponsorPercent Decimal @default(0.02) @db.Decimal(5, 4)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  product       Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor        Vendor?  @relation("ProductVendorPrices", fields: [vendorId], references: [id], onDelete: SetNull)
  serviceVendor Vendor?  @relation("ServiceVendorPrices", fields: [serviceVendorId], references: [id], onDelete: SetNull)
  currency      Currency @relation(fields: [currencyCode], references: [code])

  @@map("vendor_price_records")
}

// ===============================================
// INVOICE NOTE SECTION (NEW)
// ===============================================

model NoteCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates    NoteTemplate[]
  invoiceNotes InvoiceNote[]

  @@map("note_categories")
}

model NoteTemplate {
  id         String   @id @default(uuid())
  categoryId String
  title      String
  content    String   @db.Text
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category NoteCategory @relation(fields: [categoryId], references: [id])

  @@map("note_templates")
}

model InvoiceNote {
  id         String @id @default(uuid())
  invoiceId  Int
  categoryId String
  content    String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice  Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  category NoteCategory @relation(fields: [categoryId], references: [id])

  @@map("invoice_notes")
}

// ===============================================
// VENDOR SECTION
// ===============================================

model Vendor {
  id                  String              @id @default(uuid())
  companyName         String
  slug                String              @unique
  picName             String
  country             String?
  province            String?
  city                String?
  district            String?
  subDistrict         String?
  postalCode          String?
  address             String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isActive            Boolean             @default(true)
  trackingUrl         String?             @db.Text
  // === RELATIONS ===
  vendorItems         VendorVendorItem[]
  cashflowCost        CashflowCost[]
  // orderVendors   OrderVendor[]
  contacts            VendorContact[]
  productionJobs      ProductionTracker[]
  shipments           Shipment[]
  purchaseOrders      PurchaseOrder[]
  vendorPrices        VendorPriceRecord[] @relation("ProductVendorPrices")
  serviceVendorPrices VendorPriceRecord[] @relation("ServiceVendorPrices")

  @@map("vendors")
}

model VendorCategory {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  type        VendorType
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isActive    Boolean      @default(true)
  items       VendorItem[]

  @@map("vendor_categories")
}

model VendorItem {
  id          String             @id @default(uuid())
  categoryId  String
  slug        String             @unique
  name        String
  description String
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  category    VendorCategory     @relation(fields: [categoryId], references: [id])
  vendors     VendorVendorItem[]

  @@map("vendor_items")
}

model VendorVendorItem {
  vendorId String
  itemId   String
  vendor   Vendor     @relation(fields: [vendorId], references: [id])
  item     VendorItem @relation(fields: [itemId], references: [id])

  @@id([vendorId, itemId])
  @@map("vendor_vendor_items")
}

// ===============================================
// CONTACT SECTION
// ===============================================

model VendorContact {
  id         String   @id @default(uuid())
  vendorId   String
  platformId String
  contactId  String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendor   Vendor          @relation(fields: [vendorId], references: [id])
  platform ContactPlatform @relation(fields: [platformId], references: [id])

  @@map("vendor_contacts")
}

model ContactPlatform {
  id        String          @id @default(uuid())
  name      String
  slug      String          @unique
  icon      String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  contacts  VendorContact[]

  @@map("contact_platforms")
}

// ===============================================
// SALES SECTION (NEW)
// ===============================================

model Sales {
  id                  String               @id @default(uuid())
  prefix              String
  name                String
  phone               String
  signatureUrl        String?
  signaturePublicId   String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]
  bankAccounts        SalesBank[]
  financeTransactions FinanceTransaction[]

  @@map("sales")
}

model SalesBank {
  salesId           String
  bankName          String
  accountNumber     String
  accountHolderName String

  sales Sales @relation(fields: [salesId], references: [id])

  @@id([salesId, accountNumber])
  @@map("sales_banks")
}

// ===============================================
// ORDER SYSTEM
// ===============================================

model Order {
  id                   String                @id @default(uuid())
  orderNumber          String?               @unique
  dateOrder            DateTime
  salesCategory        SalesCategory
  // poNumber             String?
  clientPoNumber       String?
  remark               String?               @db.Text
  currencyCode         String                @default("IDR")
  currency             Currency              @relation(fields: [currencyCode], references: [code])
  referenceQuotationId String?
  referenceQuotation   Quotation?            @relation("OrderSourcedFromQuotation", fields: [referenceQuotationId], references: [id])
  referenceSampleId    String?
  referenceSample      Order?                @relation("SampleToSalesOrder", fields: [referenceSampleId], references: [id])
  resultingOrders      Order[]               @relation("SampleToSalesOrder")
  clientId             String
  shippingAddress      String
  totalAmount          Decimal
  status               OrderStatus           @default(PENDING)
  webOrderId           String?               @unique
  webOrder             WebOrder?             @relation(fields: [webOrderId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  clientB2BPICId       String?
  pic                  ClientB2BPIC?         @relation(fields: [clientB2BPICId], references: [id])
  purchaseChannelId    String?
  purchaseChannel      PurchaseChannel?      @relation(fields: [purchaseChannelId], references: [id])
  client               Client                @relation(fields: [clientId], references: [id])
  createdById          String?
  createdBy            User?                 @relation("OrderCreatedBy", fields: [createdById], references: [id])
  updatedById          String?
  updatedBy            User?                 @relation("OrderUpdatedBy", fields: [updatedById], references: [id])
  products             OrderProduct[]
  cashflows            Cashflow[]
  productionTrackers   ProductionTracker[]
  shipments            Shipment[]
  invoices             Invoice[]
  deliveryNotes        DeliveryNote[]
  quotations           Quotation[]           @relation("OrderQuotations")
  cashflowSummary      CashflowSummary[]
  sampleFollowUps      OrderSampleFollowUp[]
  purchaseOrderItems   PurchaseOrderItem[]
  warrantyDays         Int?
  warranties           OrderWarranty[]
  user                 User?                 @relation(fields: [userId], references: [id])
  userId               String?
  sales                Sales?                @relation(fields: [salesId], references: [id])
  salesId              String?
  whatsappMessages     WhatsappMessage[]

  @@map("orders")
}

model OrderWarranty {
  id              String         @id @default(uuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipmentId      String
  shipment        Shipment       @relation(fields: [shipmentId], references: [id])
  warrantyDays    Int            @default(30)
  startDate       DateTime
  expiryDate      DateTime
  status          WarrantyStatus @default(NOT_STARTED)
  isFinalShipment Boolean        @default(false)
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("order_warranties")
}

model OrderProduct {
  id                 String              @id @default(uuid())
  orderId            String
  productId          String
  quantity           Int
  unitPrice          Decimal
  customization      Json?
  remarks            String?
  order              Order               @relation(fields: [orderId], references: [id])
  product            Product             @relation(fields: [productId], references: [id])
  variantId          String?
  variant            ProductVariant?     @relation(fields: [variantId], references: [id])
  productionTrackers ProductionTracker[]
  shipmentItems      ShipmentItem[]

  @@map("order_products")
}

